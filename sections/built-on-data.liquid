<style>
      .sec-{{ section.id }} {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        padding-left: 48px;
        padding-right: 48px;
        margin: 0 auto;
      }
      @media(max-width: 768px){
        .sec-{{ section.id }} {
            padding-top: {{ section.settings.padding_top_mobile }}px;
            padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
        }
      }
      .sec-{{ section.id }} .built-on-data-container {
        position: relative;
        border-radius: {{ section.settings.border_radius }}px;
        overflow: hidden;
        background-color: #000;
        max-width:1999px;
        min-height: 485px;
        margin:0px auto;
        background-image:url('{{ section.settings.bg_image | image_url }}');
        background-position: top center;
        background-size: cover;
      }
      .sec-{{ section.id }} .content-wrapper {
        position: relative;
        z-index: 3;
        display: flex;
        flex-direction: column;
        padding: 60px 40px;
        gap: 40px;
        height: 100%;
        max-width: 1270px;
        margin: 0px auto;
      }
      @media (min-width: 768px) {
        .sec-{{ section.id }} .content-wrapper {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            padding: 80px 20px;
            gap: 60px;

        }
      }
      .sec-{{ section.id }} .left-column {
          flex: 1;;
      }
      .sec-{{ section.id }} .right-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
        width: 100%;
      }
      .sec-{{ section.id }} .section-heading {
          color: {{ section.settings.heading_color }};
          margin-bottom: 15px;
          font-weight: 500;
          font-size: 28px;
          line-height:39px;
          letter-spacing: -0.02em;
      }
      @media (min-width: 768px) {
        .sec-{{ section.id }} .section-heading {
        margin-bottom: 24px;
    }
        .sec-{{ section.id }} .left-column,
        .sec-{{ section.id }} .right-column {
            max-width: 490px;
        }
    }
      @media (min-width: 992px) {
        .sec-{{ section.id }} .section-heading {
          font-size: 40px;
          line-height:52px;
          font-weight: 500;
          letter-spacing: -0.02em;
        }
      }

      .sec-{{ section.id }} .section-text {
          color: {{ section.settings.text_color }};
          font-size: 14px;
          line-height:22px;
          letter-spacing: -0.02em;
      }
      .sec-{{ section.id }} .stat-card {
        background: linear-gradient(90deg, rgba(8, 12, 10, 0.85) 0%, rgba(18, 26, 20, 0.6) 100%);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 8px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      @media (min-width: 768px) {
        .sec-{{ section.id }} .stat-card {
            border-radius: 16px;
          flex-direction: row;
          align-items:center;
          padding: 20px 24px;;
          gap: 20px;
        }
      }
      .sec-{{ section.id }} .stat-number {
        margin: 0;
        width:100%;
        font-size: 32px;
        line-height:38px;
        letter-spacing: -0.02em;
      }

      @media (min-width: 768px) {
        .sec-{{ section.id }} .stat-number{
        max-width: 80px;
      }
    }
      @media (min-width: 992px) {
        .sec-{{ section.id }} .stat-number {
          font-size: 40px;
          line-height:52px;
          max-width: 150px;
        }
      }
      .sec-{{ section.id }} .stat-text {
        color: {{ section.settings.text_color }};
        margin: 0;
        font-size: 14px;
        line-height:22px;
        letter-spacing: -0.02em;
        width:100%;
        
      }
      @media (min-width: 768px) {
        .sec-{{ section.id }} .stat-text{
        max-width:280px;
      }
    }

      /* Mobile specific adjustments to match the design */
      @media (max-width: 767px) {
        .sec-{{ section.id }}{
            padding-left:8px;
            padding-right:8px;
        }
        .sec-{{ section.id }} .built-on-data-container {
            background-image:url('{{ section.settings.bg_image_mob | image_url }}');
            background-position: bottom center;
        }
        .sec-{{ section.id }} .content-wrapper {
          padding: 31px 16px;
          justify-content: space-between;
          gap:100px;
        }
        .sec-{{ section.id }} .right-column {
          margin-top: auto;
        }
      }
</style>

<div class="sec-{{ section.id }}">
  <div class="built-on-data-container">
    <div class="content-wrapper">
      <div class="left-column">
        {% if section.settings.heading != blank %}
          <h2 class="section-heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="section-text">{{ section.settings.text }}</div>
        {% endif %}
      </div>

      <div class="right-column">
        {% for block in section.blocks %}
          <div class="stat-card" {{ block.shopify_attributes }}>
            {% if block.settings.stat_number != blank %}
              <div class="stat-number" style="color: {{ block.settings.number_color }};">
                {{ block.settings.stat_number }}
              </div>
            {% endif %}

            {% if block.settings.stat_text != blank %}
              <div class="stat-text">
                {{ block.settings.stat_text }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Built On Data",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mob",
      "label": "Mobile background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built on Data No One Else Has"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Arccos is an AI-native platform trained on over 1.5 billion real golf shots across 10+ years of on-course play. It's the largest dataset in golf and the engine behind every feature in the app.</p>"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Section Border Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Spacing",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Spacing",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Card",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Stat Value",
          "default": "1.5B"
        },
        {
          "type": "color",
          "id": "number_color",
          "label": "Number Color",
          "default": "#65c466"
        },
        {
          "type": "richtext",
          "id": "stat_text",
          "label": "Stat Description",
          "default": "<p>Tour-proven club recommendations and strategy built on 1.5 billion shots and the same framework used to win a major championship.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Built On Data Section",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "stat_number": "1.5B",
            "stat_text": "<p>Tour-proven club recommendations and strategy built on 1.5 billion shots and the same framework used to win a major championship.</p>"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "25M",
            "stat_text": "<p>Rounds Played by Arccos members across 160 countries.</p>"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "4.2T",
            "stat_text": "<p>Data points collected with proprietary, patented technology.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

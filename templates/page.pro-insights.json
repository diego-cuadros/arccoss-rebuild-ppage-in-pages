    "custom_liquid_DKLJRj": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "liquid": "<div class=\"pro-insights-page\">\n  <!-- Left: Carousel -->\n  <div class=\"pro-insights-carousel-container\">\n    <div class=\"pro-insights-carousel\" data-align-top=\"true\">\n      <div class=\"slideshow-wrapper\">\n        <div class=\"slide one\" id=\"pro-insights-slide-one\">\n          <div class=\"background-image\">\n            <div class=\"background-image-content\">\n              <img src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Pro_Insights_v1.svg?v=1709632801\" alt=\"_\" class=\"logo-image\"/>\n              <h1 class=\"title-text\">Introducing Arccos Pro Insights</h1>\n              <p class=\"body-text\">Formerly known as StatisticGolf and founded in 2020 by Edoardo Molinari. Arccos Pro Insights is golf’s most advanced analytics for tour players. It is trusted by more than 35 players on the PGA TOUR, DP World Tour and LPGA Tour, including Matthew Fitzpatrick, Viktor Hovland and Nelly Korda.</p>\n              <p class=\"body-text mobile\">Formerly StatisticGolf and founded by Edoardo Molinari. Arccos Pro Insights is golf’s most advanced analytics for the pros. Now trusted by more than 35 tour players.</p>\n              <div class=\"slide-controls\">\n                <button type=\"button\" onclick=\"proInsightsChangeSlide(-1)\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 15 24\" fill=\"none\">\n                    <path d=\"M13 2L3 12L13 22\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                  </svg>\n                </button>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 75 15\" fill=\"none\" class=\"progress-dots\">\n                  <circle cx=\"7.5\" cy=\"7.5\" r=\"7.5\" fill=\"white\"/>\n                  <circle opacity=\"0.5\" cx=\"37.4961\" cy=\"7.5\" r=\"7.5\" fill=\"#A0ADB7\"/>\n                  <circle opacity=\"0.5\" cx=\"67.5\" cy=\"7.5\" r=\"7.5\" fill=\"#A0ADB7\"/>\n                </svg>\n                <button type=\"button\" onclick=\"proInsightsChangeSlide(1)\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 15 24\" fill=\"none\">\n                    <path d=\"M2 22.0001L12 12.0001L2 2.00006\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                  </svg>\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"slide two\" id=\"pro-insights-slide-two\">\n          <div class=\"background-image\">\n            <div class=\"background-image-content\">\n              <img src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Pro_Insights_v1.svg?v=1709632801\" alt=\"_\" class=\"logo-image\"/>\n              <h1 class=\"title-text\">Proven success at the highest levels of the game.</h1>\n              <p class=\"body-text\">Over the past 3 years, Arccos Pro Insights clients have 27 wins, including US Open, FedexCup, Ryder Cup and DP World Tour Championship titles.</p>\n              <p class=\"body-text mobile\">Over the past 3 years, Arccos Pro Insights clients have 27 wins, including US Open, FedexCup, Ryder Cup and DP World Tour Championship titles.</p>\n              <div class=\"slide-controls\">\n                <button type=\"button\" onclick=\"proInsightsChangeSlide(-1)\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 15 24\" fill=\"none\">\n                    <path d=\"M13 2L3 12L13 22\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                  </svg>\n                </button>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 75 15\" fill=\"none\" class=\"progress-dots\">\n                  <circle opacity=\"0.5\" cx=\"7.5\" cy=\"7.5\" r=\"7.5\" fill=\"#A0ADB7\"/>\n                  <circle cx=\"37.4961\" cy=\"7.5\" r=\"7.5\" fill=\"white\"/>\n                  <circle opacity=\"0.5\" cx=\"67.5\" cy=\"7.5\" r=\"7.5\" fill=\"#A0ADB7\"/>\n                </svg>\n                <button type=\"button\" onclick=\"proInsightsChangeSlide(1)\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 15 24\" fill=\"none\">\n                    <path d=\"M2 22.0001L12 12.0001L2 2.00006\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                  </svg>\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"slide three\" id=\"pro-insights-slide-three\">\n          <div class=\"background-image\">\n            <div class=\"background-image-content\">\n              <img src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Pro_Insights_v1.svg?v=1709632801\" alt=\"_\" class=\"logo-image\"/>\n              <h1 class=\"title-text\">Hailed as a ‘stats genius’ by tour players and media.</h1>\n              <p class=\"body-text\">Edoardo Molinari graduated from a 5-year engineering program before turning pro. He then leveraged his own on-course data to achieve great success – including Ryder Cup (2010), DP World Tour (3x) and US Amateur (2005) victories – peaking at #14 on the OWGR.</p>\n              <p class=\"body-text mobile\">Edoardo Molinari, an engineering graduate turned pro, used data to win Ryder Cup (2010), DP World Tour (3x), and US Amateur (2005), peaking at #14 OWGR.</p>\n              <div class=\"slide-controls\">\n                <button type=\"button\" onclick=\"proInsightsChangeSlide(-1)\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 15 24\" fill=\"none\">\n                    <path d=\"M13 2L3 12L13 22\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                  </svg>\n                </button>\n                <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 75 15\" fill=\"none\" class=\"progress-dots\">\n                  <circle opacity=\"0.5\" cx=\"7.5\" cy=\"7.5\" r=\"7.5\" fill=\"#A0ADB7\"/>\n                  <circle opacity=\"0.5\" cx=\"37.4961\" cy=\"7.5\" r=\"7.5\" fill=\"#A0ADB7\"/>\n                  <circle cx=\"67.5\" cy=\"7.5\" r=\"7.5\" fill=\"white\"/>\n                </svg>\n                <button type=\"button\" onclick=\"proInsightsChangeSlide(1)\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 15 24\" fill=\"none\">\n                    <path d=\"M2 22.0001L12 12.0001L2 2.00006\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                  </svg>\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n      </div><!-- /.slideshow-wrapper -->\n    </div><!-- /.pro-insights-carousel -->\n  </div><!-- /.pro-insights-carousel-container -->\n\n  <!-- Right: Form -->\n  <div class=\"pro-insights-form-container\">\n    <div id=\"proinsightsformsection\" class=\"pro-insights-form-section\">\n      <div class=\"modal-background\" id=\"pro-insights-modal\">\n        <div class=\"pro-insights-modal\">\n          <div class=\"loader\" id=\"pro-insights-loader\"></div>\n          <div class=\"success-message\" id=\"pro-insights-success-message\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"45\" height=\"45\" viewBox=\"0 0 45 45\" fill=\"none\">\n              <circle cx=\"22.5\" cy=\"22.5\" r=\"22.5\" fill=\"#56C271\"/>\n              <rect x=\"11.113\" y=\"21.4353\" width=\"12.7276\" height=\"3.62795\" rx=\"1.81398\" transform=\"rotate(45 11.113 21.4353)\" fill=\"white\"/>\n              <rect x=\"35.5466\" y=\"15.0011\" width=\"25.4551\" height=\"3.62757\" rx=\"1.81379\" transform=\"rotate(135 35.5466 15.0011)\" fill=\"white\"/>\n            </svg>\n            <h3>Success!</h3>\n            <p>Your information has been received.</p>\n            <p>Thank you for applying.</p>\n            <button type=\"button\" onclick=\"window.location.reload();\">Got it. Thanks!</button>\n          </div>\n          <div class=\"error-message\" id=\"pro-insights-error-message\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"44\" height=\"44\" viewBox=\"0 0 44 44\" fill=\"none\">\n              <circle cx=\"22\" cy=\"22\" r=\"22\" fill=\"#F26565\"/>\n              <path d=\"M22.137 27.1818C21.0665 27.1818 20.1747 26.3612 20.0858 25.2944L19.0111 12.3973C18.8587 10.5685 20.3019 9 22.137 9C23.9722 9 25.4154 10.5685 25.263 12.3973L24.1883 25.2944C24.0994 26.3612 23.2075 27.1818 22.137 27.1818Z\" fill=\"white\"/>\n              <path d=\"M22.137 36C20.6726 36 19.4855 34.8129 19.4855 33.3485C19.4855 31.8841 20.6726 30.697 22.137 30.697C23.6014 30.697 24.7885 31.8841 24.7885 33.3485C24.7885 34.8129 23.6014 36 22.137 36Z\" fill=\"white\"/>\n            </svg>\n            <h3>Something went wrong.</h3>\n            <p>Please try again later or reach out to starter@arccosgolf.com for support.</p>\n            <button type=\"button\" onclick=\"proInsightsCloseErrorModal()\">Try Again</button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"form-info-section-wrapper\">\n        <div class=\"form-entry-info-section\">\n          <h2 class=\"form-section-title\">Exclusive Opportunity for Pro &amp; Elite Players</h2>\n          <div class=\"form-section-text\">\n            <span class=\"text\">\n              Want to experience the advanced analytics of Arccos Pro Insights? Sign up below for your chance to be considered in our next round of players. Expansion to all golfers ahead.\n            </span>\n            <div class=\"br\"></div>\n            <br><br>\n          </div>\n        </div>\n\n        <form action=\"\" id=\"pro-insights-form\" class=\"pro-insights-form\" onchange=\"proInsightsCheckIsFormValid()\">\n          <div class=\"name-input-container\">\n            <input type=\"text\" placeholder=\"First Name\" id=\"form-first\" name=\"form-first\" class=\"form-input\" required/>\n            <input type=\"text\" placeholder=\"Last Name\" id=\"form-last\" name=\"form-last\" class=\"form-input\" required/>\n          </div>\n          <input type=\"email\" placeholder=\"Email Address\" id=\"form-email\" name=\"form-email\" class=\"form-input\" required/>\n          <input type=\"tel\" placeholder=\"Mobile\" id=\"form-phone\" name=\"form-phone\" class=\"form-input\" required/>\n          <select id=\"form-role\" name=\"form-role\" onchange=\"proInsightsShowPlayerRepInput(this)\" class=\"form-input\" required>\n            <option value=\"\" disabled selected>Select Role</option>\n            <option value=\"Player\">Player</option>\n            <option value=\"Coach\">Coach</option>\n            <option value=\"Agent\">Agent</option>\n          </select>\n          <input type=\"text\" placeholder=\"Player Name(s) You Represent\" id=\"form-players\" name=\"form-players\" style=\"display:none\" class=\"form-input\"/>\n          <input type=\"submit\" id=\"form-submit-button\" class=\"form-submit-button\" disabled/>\n        </form>\n      </div>\n    </div>\n  </div><!-- /.pro-insights-form-container -->\n</div><!-- /.pro-insights-page -->\n\n<style>\n  /* Layout */\n  .pro-insights-page { display:flex; width:100%; min-height:100vh; }\n  .pro-insights-carousel-container { width:63.5%; flex-grow:1; }\n  .pro-insights-form-container { width:36.5%; min-width:490px; max-width:585px; flex-grow:0; }\n  @media (max-width: 768px) {\n    .pro-insights-page { flex-direction:column; }\n    .pro-insights-carousel-container { width:100%; flex-grow:0; }\n    .pro-insights-form-container { width:100%; max-width:unset; min-width:unset; }\n  }\n\n  /* Carousel */\n  .pro-insights-carousel .slideshow-wrapper { width:100%; height:100vh; background-color:#242424; }\n  .pro-insights-carousel .slideshow-wrapper .slide { width:100%; height:100%; display:none; animation: fadeIn 2s; }\n  .pro-insights-carousel .slideshow-wrapper .slide.one { display:block; }\n  .pro-insights-carousel .slideshow-wrapper .slide-controls { display:flex; align-items:center; }\n  .pro-insights-carousel .slideshow-wrapper .slide-controls button { line-height:unset; display:flex; justify-content:center; align-items:center; }\n  .pro-insights-carousel .slideshow-wrapper .slide-controls button svg { width:10px; height:20px; }\n  .pro-insights-carousel .slideshow-wrapper .slide-controls .progress-dots { margin:0 10px; width:65px; height:13px; }\n\n  .pro-insights-carousel .slideshow-wrapper .slide.one .background-image { background:url(\"https://cdn.arccosgolf.com/images/shopify/pro-insights-slide1.png\") top/cover; }\n  .pro-insights-carousel .slideshow-wrapper .slide.two .background-image { background:url(\"https://cdn.arccosgolf.com/images/shopify/pro-insights-slide2-desktop.png\") top/cover; }\n  .pro-insights-carousel .slideshow-wrapper .slide.three .background-image { background:url(\"https://cdn.arccosgolf.com/images/shopify/pro-insights-slide3-desktop3.png\") top/cover; }\n\n  .pro-insights-carousel .background-image-content {\n    background: linear-gradient(180deg, rgba(67,75,89,0.40) 41.42%, #242424 100%);\n    height:100vh; display:flex; flex-direction:column; justify-content:flex-end; padding:0 7% 10%;\n  }\n  .pro-insights-carousel .title-text { color:#fff; font-size:44px; font-weight:700; line-height:105%; margin-bottom:30px; }\n  .pro-insights-carousel .body-text { color:#F2F2F2; font-size:16px; font-weight:500; line-height:120%; max-width:70%; margin-bottom:75px; min-height:max(96px,10%); }\n  .pro-insights-carousel .body-text.mobile { display:none; margin-bottom:30px; }\n  .pro-insights-carousel .logo-image { height:80px; width:250px; margin-bottom:30px; }\n\n  @keyframes fadeIn { from { opacity:0.1; color:rgba(255,255,255,0);} to { opacity:1; color:rgba(255,255,255,1);} }\n\n  @media (max-width: 768px) {\n    .pro-insights-carousel .slideshow-wrapper .slide.one .background-image { background:url(\"https://cdn.arccosgolf.com/images/shopify/pro-insights-slide1-mobile.png\") top/cover; }\n    .pro-insights-carousel .slideshow-wrapper .slide.two .background-image { background:url(\"https://cdn.arccosgolf.com/images/shopify/pro-insights-slide2-mobile.png\") top/cover; }\n    .pro-insights-carousel .slideshow-wrapper .slide.three .background-image { background:url(\"https://cdn.arccosgolf.com/images/shopify/pro-insights-slide3-mobile2.png\") top/cover; }\n    .pro-insights-carousel .slideshow-wrapper { height:unset; }\n    .pro-insights-carousel .slideshow-wrapper .slide-controls button svg { width:7px; height:14px; }\n    .pro-insights-carousel .slideshow-wrapper .slide-controls .progress-dots { margin:0 10px; width:50px; height:10px; }\n    .pro-insights-carousel .background-image-content { height:auto; min-height:350px; padding: 0 30px 40px; }\n    .pro-insights-carousel .title-text { font-size:22px; margin-bottom:15px; }\n    .pro-insights-carousel .body-text { display:none; }\n    .pro-insights-carousel .body-text.mobile { font-size:14px; display:block; max-width:unset; padding-right:21px; }\n    .pro-insights-carousel .logo-image { width:150px; height:48px; margin-bottom:15px; }\n  }\n\n  /* Form */\n  .pro-insights-form-section { height:100%; }\n  .pro-insights-form-section .modal-background {\n    position: fixed; top:0; left:0; width:100vw; height:100vh; background:rgba(36,36,36,0.60); visibility:hidden; z-index:9999;\n  }\n  .pro-insights-form-section .modal-background .pro-insights-modal {\n    background:#fff; width:28%; height:36%; margin:17% 36%; border-radius:5px; display:flex; flex-direction:column; align-items:center; justify-content:center;\n  }\n  .pro-insights-form-section .modal-background .pro-insights-modal > *:not(:first-child) {\n    flex-direction:column; align-items:center; justify-content:center; width:80%; display:none;\n  }\n  .loader { border:5px solid rgba(36,36,36,0.4); border-top:5px solid #242424; border-radius:50%; width:40px; height:40px; animation:spin 1s linear infinite; }\n  @keyframes spin { 0% {transform:rotate(0);} 100% {transform:rotate(360deg);} }\n  .pro-insights-form-section .modal-background .pro-insights-modal h3 { color:#575B65; text-align:center; font-size:24px; font-weight:600; line-height:115%; margin:20px 0; }\n  .pro-insights-form-section .modal-background .pro-insights-modal p { color:#828E96; text-align:center; font-size:14px; font-weight:500; line-height:125%; margin:0; padding:0; }\n  .pro-insights-form-section .modal-background .pro-insights-modal button { border-radius:5px; background:#575B65; min-height:44px; width:100%; margin-top:30px; color:#fff; font-weight:600; }\n\n  .pro-insights-form-section .form-info-section-wrapper { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:0 68px; }\n  .pro-insights-form-section .form-info-section-wrapper .form-section-title { text-transform:unset; color:#3D3F44; text-align:center; font-family:Montserrat, sans-serif; font-size:32px; font-weight:700; line-height:115%; letter-spacing:-0.96px; margin-bottom: 24px;}\n  .pro-insights-form-section .form-info-section-wrapper .form-section-text { color:#A0ADB7; text-align:center; font-size:16px; font-weight:500; line-height:115%; padding:0 10px; margin-bottom: 24px;}\n  .pro-insights-form-section .pro-insights-form { display:flex; flex-direction:column; align-items:center; padding:0 35px; }\n  .pro-insights-form-section .pro-insights-form > *:not(:last-child) { margin-bottom:10px; }\n  .pro-insights-form-section .name-input-container { display:flex; }\n  .pro-insights-form-section .form-input { width:100%; min-height:52px; border:#626A77 solid 1px; border-radius:5px; color:#252628; font-size:14px!important; font-weight:600; line-height:125%; padding: 14px 16px;}\n  .pro-insights-form-section .name-input-container > *:first-child { margin-right:5px; border-radius:5px 0 0 5px; }\n  .pro-insights-form-section .name-input-container > *:last-child { border-radius:0 5px 5px 0; }\n  .pro-insights-form-section .form-submit-button { width:100%; border:none; border-radius:5px; background:#56C271; color:#fff; text-align:center; font-family:Montserrat, sans-serif; font-size:16px; font-weight:700; letter-spacing:-0.32px; text-transform:uppercase; min-height:52px; margin-top:25px; }\n  .pro-insights-form-section .form-submit-button:disabled { background:#D1D6DA; }\n\n  @media (max-width: 768px) {\n    .pro-insights-form-section .modal-background .pro-insights-modal { width:84%; height:23%; margin:65% 8%; }\n    .pro-insights-form-section .form-info-section-wrapper { padding:30px 30px; }\n    .pro-insights-form-section .form-info-section-wrapper .form-section-title { font-size:24px; margin-bottom:16px; }\n    .pro-insights-form-section .form-info-section-wrapper .form-section-text { font-size:14px; padding:0; font-weight:500; line-height:115%; }\n    .pro-insights-form-section .pro-insights-form { padding:0 10px; }\n    .pro-insights-form-section .pro-insights-form > *:not(:last-child) { margin-bottom:15px; }\n  }\n</style>\n\n<script>\n  /* Carousel */\n  window.proInsightsActiveSlide = 1;\n  function proInsightsDisplaySlides() {\n    document.getElementById(\"pro-insights-slide-one\").style.display   = (window.proInsightsActiveSlide === 1) ? \"block\" : \"none\";\n    document.getElementById(\"pro-insights-slide-two\").style.display   = (window.proInsightsActiveSlide === 2) ? \"block\" : \"none\";\n    document.getElementById(\"pro-insights-slide-three\").style.display = (window.proInsightsActiveSlide === 3) ? \"block\" : \"none\";\n  }\n  function proInsightsChangeSlide(num) {\n    var temp = window.proInsightsActiveSlide + num;\n    if (temp > 3) window.proInsightsActiveSlide = 1;\n    else if (temp < 1) window.proInsightsActiveSlide = 3;\n    else window.proInsightsActiveSlide = temp;\n\n    proInsightsDisplaySlides();\n    clearTimeout(window.proInsightsAutoplay);\n    window.proInsightsAutoplay = setTimeout(function(){ proInsightsChangeSlide(1); }, 15000);\n  }\n  document.addEventListener('DOMContentLoaded', function(){\n    proInsightsDisplaySlides();\n    window.proInsightsAutoplay = setTimeout(function(){ proInsightsChangeSlide(1); }, 15000);\n  });\n\n  /* Form */\n  function proInsightsScrollToTop() {\n    document.body.scrollTop = 0;\n    document.documentElement.scrollTop = 0;\n  }\n  async function proInsightsHandleSubmit(e) {\n    document.getElementById(\"pro-insights-modal\").style.visibility = \"visible\";\n\n    var email = e.target['form-email'].value;\n    var firstName = e.target['form-first'].value;\n    var lastName = e.target['form-last'].value;\n    var phone = e.target['form-phone'].value;\n    var role = e.target['form-role'].value;\n    var playerNames = e.target['form-players'].value;\n\n    try {\n      var response = await window.fetch('https://api.arccosgolf.com/users/shopify/form', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({\n          form_key: \"PRO_INSIGHTS_FORM\",\n          form_data: {\n            firstName, lastName, email, phone, role,\n            playerNames: role !== 'Player' ? playerNames : null\n          }\n        })\n      });\n\n      proInsightsScrollToTop();\n      document.getElementById(\"pro-insights-loader\").style.display=\"none\";\n      if (response.status === 200) {\n        document.getElementById(\"pro-insights-success-message\").style.display=\"flex\";\n      } else {\n        document.getElementById(\"pro-insights-error-message\").style.display=\"flex\";\n      }\n    } catch (err) {\n      proInsightsScrollToTop();\n      document.getElementById(\"pro-insights-loader\").style.display=\"none\";\n      document.getElementById(\"pro-insights-error-message\").style.display=\"flex\";\n    }\n  }\n  function proInsightsSetupForm() {\n    var form = document.getElementById('pro-insights-form');\n    if (form) {\n      form.addEventListener('submit', function(e){\n        e.preventDefault();\n        proInsightsHandleSubmit(e);\n      });\n    }\n    if (typeof window.jQuery !== 'undefined') {\n      var $ = window.jQuery;\n      $('p').filter(function(){ return $(this).text() === 'NOT A MEMBER?'; })\n        .attr('name', 'arccos-bundle-anchor')\n        .attr('id', 'arccos-bundle-anchor');\n    }\n  }\n  function proInsightsShowPlayerRepInput(el) {\n    var input = document.getElementById(\"form-players\");\n    if (!input) return;\n    if (el.value === 'Coach' || el.value === 'Agent') {\n      input.style.display = \"block\";\n      input.required = true;\n    } else {\n      input.style.display = \"none\";\n      input.required = false;\n    }\n  }\n  function proInsightsCloseErrorModal() {\n    document.getElementById(\"pro-insights-modal\").style.visibility=\"hidden\";\n    document.getElementById(\"pro-insights-error-message\").style.display=\"none\";\n    document.getElementById(\"pro-insights-loader\").style.display=\"block\";\n  }\n  function proInsightsCheckEmpty(el){ return !el || el.value === \"\"; }\n  function proInsightsCheckIsFormValid() {\n    var email = document.getElementById(\"form-email\");\n    var first = document.getElementById(\"form-first\");\n    var last  = document.getElementById(\"form-last\");\n    var phone = document.getElementById(\"form-phone\");\n    var role  = document.getElementById(\"form-role\");\n    var players = document.getElementById(\"form-players\");\n    var allow =\n      !proInsightsCheckEmpty(email) &&\n      !proInsightsCheckEmpty(first) &&\n      !proInsightsCheckEmpty(last) &&\n      !proInsightsCheckEmpty(phone) &&\n      role && role.value &&\n      (role.value === 'Player' || ((role.value === 'Coach' || role.value === 'Agent') && !proInsightsCheckEmpty(players)));\n    var btn = document.getElementById(\"form-submit-button\");\n    if (btn) { btn.disabled = !allow; }\n  }\n  document.addEventListener('DOMContentLoaded', proInsightsSetupForm);\n</script>",

      "settings": {
        "liquid": "<style>\n    #shopify-section-pro-insights-form {\n        width: 36.5%;\n        min-width: 490px;\n        max-width: 585px;\n      flex-grow: 0;\n    }\n    .pro-insights-form-section {\n        height: 100%;\n    }\n    .pro-insights-form-section .modal-background {\n        position: absolute;\n        top: 0;\n        left: 0;\n        width: 100vw;\n        height: 100vh;\n        background: rgba(36, 36, 36, 0.60);\n        visibility: hidden;\n    }\n    .pro-insights-form-section .modal-background .pro-insights-modal {\n        background: white;\n        width: 28%;\n        height: 36%;\n        margin: 17% 36%;\n        border-radius: 5px;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n    }\n    .pro-insights-form-section .modal-background .pro-insights-modal > *:not(:first-child) {\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        width: 80%;\n        display: none;\n    }\n    .loader {\n      border: 5px solid rgba(36, 36, 36, 0.4); /* Light grey */\n      border-top: 5px solid #242424; /* Blue */\n      border-radius: 50%;\n      width: 40px;\n      height: 40px;\n      animation: spin 1s linear infinite;\n    }\n    \n    @keyframes spin {\n      0% { transform: rotate(0deg); }\n      100% { transform: rotate(360deg); }\n    }\n    .pro-insights-form-section .modal-background .pro-insights-modal h3 {\n        color: #575B65;\n        text-align: center;\n        font-size: 24px;\n        font-style: normal;\n        font-weight: 600;\n        line-height: 115%;\n        text-transform: unset;\n        margin: 20px 0;\n    }\n    .pro-insights-form-section .modal-background .pro-insights-modal p {\n        color: #828E96;\n        text-align: center;\n        font-size: 14px;\n        font-style: normal;\n        font-weight: 500;\n        line-height: 125%;\n        margin: 0;\n        padding: 0;\n    }\n    .pro-insights-form-section .modal-background .pro-insights-modal button {\n        border-radius: 5px;\n        background: #575B65;\n        min-height: 44px;\n        width: 100%;\n        margin-top: 30px;\n        color: white;\n        font-weight: 600;\n    }\n    .pro-insights-form-section .form-info-section-wrapper {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        height: 100%;\n        padding: 0 68px;\n    }\n    .pro-insights-form-section .form-info-section-wrapper \n    .pro-insights-form-section .form-info-section-wrapper .form-section-text {\n        color: #A0ADB7;\n        text-align: center;\n        font-size: 16px;\n        font-style: normal;\n        font-weight: 500;\n        line-height: 115%;\n        padding: 0 10px;\n    }\n    .pro-insights-form-section .form-info-section-wrapper .form-entry-info-section {\n        text-align: center;\n    }\n    .pro-insights-form-section .pro-insights-form {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        padding: 0 35px;\n    }\n    .pro-insights-form-section .pro-insights-form > *:not(:last-child) {\n        margin-bottom: 10px;\n    }\n    .pro-insights-form-section .name-input-container {\n        display: flex;\n    }\n    .pro-insights-form-section .form-input {\n        width: 100%;\n        min-height: 52px;\n        border: #626A77 solid 1px;\n        border-radius: 5px;\n        color: #252628;\n        font-size: 14px!important;\n        font-style: normal;\n        font-weight: 600;\n        line-height: 125%;\n    }\n    .pro-insights-form-section .name-input-container > *:first-child {\n        margin-right: 5px;\n        border-radius: 5px 0 0 5px;\n    }\n    .pro-insights-form-section .name-input-container > *:last-child {\n        border-radius: 0 5px 5px 0;\n    }\n    .pro-insights-form-section .form-submit-button {\n        width: 100%;\n        border: none;\n        border-radius: 5px;\n        background-color: #56C271;\n        color: white;\n        text-align: center;\n        font-family: Montserrat, sans-serif;\n        font-size: 16px;\n        font-style: normal;\n        font-weight: 700;\n        line-height: normal;\n        letter-spacing: -0.32px;\n        text-transform: uppercase;\n        min-height: 52px;\n        margin-top: 25px;\n    }\n    .pro-insights-form-section .form-submit-button:disabled {\n        background: #D1D6DA;\n    }\n    @media screen and (max-width: 768px) {\n        #shopify-section-pro-insights-form {\n            width: 100%;\n            max-width: unset;\n            min-width: unset;\n        }\n      .pro-insights-form-section .modal-background .pro-insights-modal {\n        width: 84%;\n        height: 23%;\n        margin: 65% 8%;\n      }\n        .pro-insights-form-section .form-info-section-wrapper {\n            padding: 30px 30px;\n        }\n        .pro-insights-form-section .form-info-section-wrapper .form-section-title {\n            font-size: 24px;\n            margin-bottom: 16px;\n        }\n        .pro-insights-form-section .form-info-section-wrapper .form-section-text {\n            font-size: 14px;\n            padding: 0;\n            font-weight: 500;\n            line-height: 115%;\n        }\n        .pro-insights-form-section .pro-insights-form {\n            padding: 0 10px;\n        }\n        .pro-insights-form-section .pro-insights-form > *:not(:last-child) {\n            margin-bottom: 15px;\n        }\n    }\n</style>\n<script>\n    let failureCount = 0\n    const handleSubmit = async e => {\n        document.getElementById(\"pro-insights-modal\").style.visibility=\"visible\"\n        const email = e.target['form-email'].value\n        const firstName = e.target['form-first'].value\n        const lastName = e.target['form-last'].value\n        const phone = e.target['form-phone'].value\n        const role = e.target['form-role'].value\n        const playerNames = e.target['form-players'].value\n        const response = await window.fetch('https://api.arccosgolf.com/users/shopify/form', {\n            method: 'POST',\n            headers: {\n                'Content-Type': 'application/json',\n            },\n            body: JSON.stringify({\n                form_key: \"PRO_INSIGHTS_FORM\",\n                form_data: {\n                    firstName,\n                    lastName,\n                    email,\n                    phone,\n                    role,\n                    playerNames: role !== 'Player' ? playerNames : null\n                }\n            })\n        })\n        console.log({response})\n        if (response.status === 200) {\n            scrollToTop()\n            document.getElementById(\"pro-insights-loader\").style.display=\"none\"\n            document.getElementById(\"pro-insights-success-message\").style.display=\"flex\"\n        } else {\n            scrollToTop()\n            document.getElementById(\"pro-insights-loader\").style.display=\"none\"\n            document.getElementById(\"pro-insights-error-message\").style.display=\"flex\"\n        }\n    }\n    function scrollToTop() {\n        document.body.scrollTop = 0; // For Safari\n        document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera\n    }\n    const setup = () => {\n        console.log('setup')\n        $('#pro-insights-form')\n            .removeAttr('onsubmit')\n            .submit(e => {\n                e.preventDefault()\n                handleSubmit(e)\n            })\n        $('p').filter(function () {\n            return $(this).text() === 'NOT A MEMBER?'\n        })\n            .attr('name', 'arccos-bundle-anchor')\n            .attr('id', 'arccos-bundle-anchor')\n    }\n    let intervalId\n    if (!intervalId) {\n        console.log('interval id')\n        intervalId = setInterval(() => {\n            if (typeof $ !== 'undefined') {\n                clearInterval(intervalId)\n                intervalId = undefined\n                setup()\n            }\n        }, 300)\n    }\n    const showPlayerRepInput = (e) => {\n        if (e.value === 'Coach' || e.value === 'Agent') {\n            document.getElementById(\"form-players\").style.display=\"block\"\n            document.getElementById(\"form-players\").required=true\n        } else {\n            document.getElementById(\"form-players\").style.display=\"none\"\n            document.getElementById(\"form-players\").required=false\n        }\n    }\n    const closeErrorModal = () => {\n        document.getElementById(\"pro-insights-modal\").style.visibility=\"hidden\"\n        document.getElementById(\"pro-insights-error-message\").style.display=\"none\"\n    }\n    function checkEmpty(obj) {\n        console.log(obj)\n        console.log($(obj).val())\n        if($(obj).val() === \"\") {\n            return true;\n        }\n        return false;\n    }\n    const checkIsFormValid = () => {\n        console.log('checking form')\n        if (!checkEmpty($(\"#form-email\")) && !checkEmpty($(\"#form-first\")) && !checkEmpty($(\"#form-last\")) && !checkEmpty($(\"#form-phone\")) && ($(\"#form-role\").val() === 'Player' || (($(\"#form-role\").val() === 'Coach' || $(\"#form-role\").val() === 'Agent') && !checkEmpty($(\"#form-players\"))))) {\n            $(\"#form-submit-button\").removeAttr(\"disabled\")\n        } else {\n            document.getElementById(\"form-submit-button\").disabled=true\n        }\n    }\n</script>\n<div id=\"proinsightsformsection\" name=\"proinsightsformsection\" class=\"pro-insights-form-section\">\n    <div class=\"modal-background\" id=\"pro-insights-modal\">\n        <div class=\"pro-insights-modal\">\n            <div class=\"loader\" id=\"pro-insights-loader\"></div>\n            <div class=\"success-message\" id=\"pro-insights-success-message\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"45\" height=\"45\" viewBox=\"0 0 45 45\" fill=\"none\">\n                    <circle cx=\"22.5\" cy=\"22.5\" r=\"22.5\" fill=\"#56C271\"/>\n                    <rect x=\"11.113\" y=\"21.4353\" width=\"12.7276\" height=\"3.62795\" rx=\"1.81398\" transform=\"rotate(45 11.113 21.4353)\" fill=\"white\"/>\n                    <rect x=\"35.5466\" y=\"15.0011\" width=\"25.4551\" height=\"3.62757\" rx=\"1.81379\" transform=\"rotate(135 35.5466 15.0011)\" fill=\"white\"/>\n                </svg>\n                <h3>Success!</h3>\n                <p>Your information has been received.</p>\n                <p>Thank you for applying.</p>\n                <button type=\"button\" onclick=\"window.location.reload();\">Got it. Thanks!</button>\n            </div>\n            <div class=\"error-message\" id=\"pro-insights-error-message\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"44\" height=\"44\" viewBox=\"0 0 44 44\" fill=\"none\">\n                <circle cx=\"22\" cy=\"22\" r=\"22\" fill=\"#F26565\"/>\n                <path d=\"M22.137 27.1818C21.0665 27.1818 20.1747 26.3612 20.0858 25.2944L19.0111 12.3973C18.8587 10.5685 20.3019 9 22.137 9C23.9722 9 25.4154 10.5685 25.263 12.3973L24.1883 25.2944C24.0994 26.3612 23.2075 27.1818 22.137 27.1818Z\" fill=\"white\"/>\n                <path d=\"M22.137 36C20.6726 36 19.4855 34.8129 19.4855 33.3485C19.4855 31.8841 20.6726 30.697 22.137 30.697C23.6014 30.697 24.7885 31.8841 24.7885 33.3485C24.7885 34.8129 23.6014 36 22.137 36Z\" fill=\"white\"/>\n              </svg>\n                <h3>Something went wrong.</h3>\n                <p>Please try again later or reach out to starter@arccosgolf.com for support.</p>\n                <button type=\"button\" onclick=\"closeErrorModal()\">Try Again</button>\n            </div>\n        </div>\n    </div>\n        <div class=\"form-info-section-wrapper\">\n            <div id=\"form-entry-info-section\" class=\"form-entry-info-section\">\n               \n                <div class=\"form-section-text\">\n                  \n                    <div class=\"br\"></div>\n                    \n                </div>\n            </div>\n            <form action=\"\" id=\"pro-insights-form\" class=\"pro-insights-form\" onchange=\"checkIsFormValid()\" >\n                <div class=\"name-input-container\">\n                    <input\n                            type=\"text\"\n                            placeholder=\"First Name\"\n                            id=\"form-first\"\n                            name=\"form-first\"\n                            class=\"form-input\"\n                            required\n                    />\n                    <input\n                            type=\"text\"\n                            placeholder=\"Last Name\"\n                            id=\"form-last\"\n                            name=\"form-last\"\n                            class=\"form-input\"\n                            required\n                    />\n                </div>\n                <input\n                        type=\"email\"\n                        placeholder=\"Email Address\"\n                        id=\"form-email\"\n                        name=\"form-email\"\n                        class=\"form-input\"\n                        required\n                />\n                <input\n                        type=\"tel\"\n                        placeholder=\"Mobile\"\n                        id=\"form-phone\"\n                        name=\"form-phone\"\n                        class=\"form-input\"\n                        required\n                />\n                <select id=\"form-role\" name=\"form-role\" onchange=\"showPlayerRepInput(this)\" class=\"form-input\" required>\n                    <option value=\"\" disabled selected>Select Role</option>\n                    <option value=\"Player\">Player</option>\n                    <option value=\"Coach\">Coach</option>\n                    <option value=\"Agent\">Agent</option>\n                </select>\n                <input\n                        type=\"text\"\n                        placeholder=\"Player Name(s) You Represent\"\n                        id=\"form-players\"\n                        name=\"form-players\"\n                        style=\"display:none\"\n                        class=\"form-input\"\n                />\n                <input type=\"submit\" id=\"form-submit-button\" class=\"form-submit-button\" disabled/>\n            </form>\n        </div>\n</div>",

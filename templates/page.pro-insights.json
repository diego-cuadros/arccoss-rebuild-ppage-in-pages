    "custom_liquid_3hiHnL": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "liquid": "<style>\n  .pro-insights-form-section {\n    max-width: 585px;\n    margin: 0 auto;\n    font-family: Montserrat, sans-serif;\n  }\n\n  /* Modal */\n  .pro-insights-form-section .modal-background {\n    position: fixed;\n    top: 0; left: 0;\n    width: 100vw; height: 100vh;\n    background: rgba(36,36,36,0.6);\n    visibility: hidden;\n    z-index: 9999;\n  }\n  .pro-insights-form-section .pro-insights-modal {\n    background: #fff;\n    width: 90%; max-width: 400px;\n    margin: 20% auto;\n    border-radius: 6px;\n    padding: 30px;\n    text-align: center;\n  }\n  .loader {\n    border: 5px solid rgba(36,36,36,0.3);\n    border-top: 5px solid #242424;\n    border-radius: 50%;\n    width: 40px; height: 40px;\n    margin: 0 auto;\n    animation: spin 1s linear infinite;\n  }\n  @keyframes spin { 0%{transform:rotate(0)} 100%{transform:rotate(360deg)} }\n\n  /* Form */\n  .pro-insights-form {\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n    margin-top: 24px;\n  }\n  .name-input-container {\n    display: flex;\n    gap: 8px;\n  }\n  .form-input {\n    flex: 1;\n    padding: 14px 16px;\n    border: 1px solid #626A77;\n    border-radius: 5px;\n    font-size: 15px;\n    font-weight: 500;\n  }\n  .form-submit-button {\n    padding: 14px 16px;\n    border: none;\n    border-radius: 5px;\n    background: #56C271;\n    color: #fff;\n    font-weight: 700;\n    text-transform: uppercase;\n    cursor: pointer;\n  }\n  .form-submit-button:disabled { background: #D1D6DA; }\n\n/* Mobile tweak: stack first/last name */\n@media (max-width: 600px) {\n  .pro-insights-form .name-input-container {\n    flex-direction: column;\n    gap: 12px; /* space between stacked fields */\n  }\n}\n</style>\n\n<script>\n  async function handleSubmit(e) {\n    e.preventDefault();\n    document.getElementById(\"pro-insights-modal\").style.visibility = \"visible\";\n\n    const form = e.target;\n    const data = {\n      firstName: form['form-first'].value,\n      lastName: form['form-last'].value,\n      email: form['form-email'].value,\n      phone: form['form-phone'].value,\n      role: form['form-role'].value,\n      playerNames: form['form-role'].value !== 'Player' ? form['form-players'].value : null\n    };\n\n    try {\n      const response = await fetch('https://api.arccosgolf.com/users/shopify/form', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ form_key: \"PRO_INSIGHTS_FORM\", form_data: data })\n      });\n\n      document.getElementById(\"pro-insights-loader\").style.display = \"none\";\n      if (response.status === 200) {\n        document.getElementById(\"pro-insights-success-message\").style.display = \"block\";\n      } else {\n        document.getElementById(\"pro-insights-error-message\").style.display = \"block\";\n      }\n    } catch (err) {\n      document.getElementById(\"pro-insights-loader\").style.display = \"none\";\n      document.getElementById(\"pro-insights-error-message\").style.display = \"block\";\n    }\n  }\n\n  function showPlayerRepInput(e) {\n    const players = document.getElementById(\"form-players\");\n    if (e.value === 'Coach' || e.value === 'Agent') {\n      players.style.display = \"block\";\n      players.required = true;\n    } else {\n      players.style.display = \"none\";\n      players.required = false;\n    }\n  }\n\n  function closeErrorModal() {\n    document.getElementById(\"pro-insights-modal\").style.visibility=\"hidden\";\n    document.getElementById(\"pro-insights-error-message\").style.display=\"none\";\n    document.getElementById(\"pro-insights-loader\").style.display=\"block\";\n  }\n</script>\n\n<div class=\"pro-insights-form-section\">\n  <!-- Modal -->\n  <div class=\"modal-background\" id=\"pro-insights-modal\">\n    <div class=\"pro-insights-modal\">\n      <div class=\"loader\" id=\"pro-insights-loader\"></div>\n      <div class=\"success-message\" id=\"pro-insights-success-message\" style=\"display:none\">\n        <h3>Success!</h3>\n        <p>Your information has been received.</p>\n        <button onclick=\"window.location.reload()\">Got it. Thanks!</button>\n      </div>\n      <div class=\"error-message\" id=\"pro-insights-error-message\" style=\"display:none\">\n        <h3>Something went wrong.</h3>\n        <p>Please try again later or email starter@arccosgolf.com</p>\n        <button onclick=\"closeErrorModal()\">Try Again</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- Form -->\n  <form id=\"pro-insights-form\" class=\"pro-insights-form\" onsubmit=\"handleSubmit(event)\">\n    <div class=\"name-input-container\">\n      <input type=\"text\" id=\"form-first\" name=\"form-first\" class=\"form-input\" placeholder=\"First Name\" required>\n      <input type=\"text\" id=\"form-last\" name=\"form-last\" class=\"form-input\" placeholder=\"Last Name\" required>\n    </div>\n    <input type=\"email\" id=\"form-email\" name=\"form-email\" class=\"form-input\" placeholder=\"Email Address\" required>\n    <input type=\"tel\" id=\"form-phone\" name=\"form-phone\" class=\"form-input\" placeholder=\"Mobile\" required>\n    <select id=\"form-role\" name=\"form-role\" class=\"form-input\" onchange=\"showPlayerRepInput(this)\" required>\n      <option value=\"\" disabled selected>Select Role</option>\n      <option value=\"Player\">Player</option>\n      <option value=\"Coach\">Coach</option>\n      <option value=\"Agent\">Agent</option>\n    </select>\n    <input type=\"text\" id=\"form-players\" name=\"form-players\" class=\"form-input\" placeholder=\"Player Name(s) You Represent\" style=\"display:none\">\n    <button type=\"submit\" id=\"form-submit-button\" class=\"form-submit-button\" disabled>Submit</button>\n  </form>\n</div>",
        "color_text": "",

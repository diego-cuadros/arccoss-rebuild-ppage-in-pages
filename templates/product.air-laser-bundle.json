        "testimonial_Kmtmt8": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>Arccos Air has been a real game changer for me. I just put it in my pocket and it collects all this amazing data.</p>",
            "author": "Mike Ballo",
            "author_info": "Head Professional at Tamarack CC",
            "author_url": "",
            "image": "shopify://shop_images/MikeBalloHeadshot.jpg",

            "highlighted_scribble": "circle"
          }
        },
        "testimonial_RkbdTU": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>With Arccos Air, all you have to do is put it in your pocket, and go play golf. No sensors and no phone. It couldn't be easier — and it allows me to completely focus on my game when I'm out there competing.</p>",
            "author": "Mario Guerra",
            "author_info": "Head Professional at Quaker Ridge GC",
            "author_url": "",
            "image": "shopify://shop_images/MarioGuerraHeadshot.jpg",
            "image_ratio": "rounded",
            "button_label": "",

    "faq_8XYCd7": {
      "type": "faq",
      "blocks": {
        "question_kkQ9cg": {
          "type": "question",
          "settings": {
            "title": "What makes the Arccos Smart Laser different from other rangefinders?",
            "text": "<p>It’s the only rangefinder that combines best-in-class optics with real-time plays-like yardages automatically adjusted for slope, wind, temperature, altitude, and more. It also syncs pin positions to the Arccos app for more accurate stat tracking with less manual work.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_Xzd3JJ": {
          "type": "question",
          "settings": {
            "title": "What happens if I lose or break my Smart Laser?",
            "text": "<p>If your device is lost or damaged, you’ll be able to purchase a replacement for a one-time fee. Your subscription remains active and tied to your account.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_9zMmkd": {
          "type": "question",
          "settings": {
            "title": "How easy are the sensors to install?",
            "text": "<p>Arccos Smart Sensors are really easy to install with twist-in sensors that are compatible with most golf clubs. Typical set up takes less than 10 minutes but requires an internet connection.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_afAany": {
          "type": "question",
          "settings": {
            "title": "Is my course mapped?",
            "text": "<p>We have over 40,000 courses mapped in our system. To see if your course is mapped, use our course search tool.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_MWPHXT": {
          "type": "question",
          "settings": {
            "title": "Do sensors require battery replacements?",
            "text": "<p>Batteries are not replaceable. The sensors have a 2-year guarantee and each member receives 5 new sensors upon membership renewal.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_4UrTNM": {
          "type": "question",
          "settings": {
            "title": "Are the sensors waterproof?",
            "text": "<p>Arccos Smart Sensors are weather and dust resistant. If you get caught out by the weather mid-round, don't worry we'll keep tracking your shots!</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },

    "custom_liquid_3hiHnL": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "liquid": "<style>\n    .sweepstakes-form-section {\n        font-family: 'Montserrat', sans-serif;\n        text-align: center;\n\n        font-size: 4px;\n        position: relative;\n\n        --color-1: #3D3F44;\n        --color-3: #B2BEC6;\n        --color-4: #A0ADB7;\n        --arccos-green: #56C271;\n        --disabled-button-color: #8F8F8F;\n        --shopify-root-font-size: 16px;\n    }\n\n    .sweepstakes-form-section * {\n        box-sizing: border-box;\n        margin: 0;\n        padding: 0;\n    }\n\n    #sweepstakes-entry-layout {\n        padding-top: 20em;\n        padding-bottom: 20em;\n    }\n\n    #sweepstakes-success-layout {\n        position: absolute;\n        top: 0;\n        left: 0;\n        height: 100%;\n        width: 100%;\n        display: none;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n    }\n\n    #sweepstakes-failure-info-section {\n        position: absolute;\n        height: 100%;\n        width: 100%;\n        display: none;\n        top: 0;\n        left: 0;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n    }\n\n    .sweepstakes-form-section .sweepstakes-info-section-wrapper {\n        position: relative;\n    }\n\n    .sweepstakes-form-section .sweepstakes-section-text {\n        font-size: var(--shopify-root-font-size);\n        margin-bottom: calc(15em / 8);\n        max-width: 46em;\n    }\n\n    .sweepstakes-form-section .br:before {\n        white-space: pre;\n        content: '\\A';\n    }\n\n    .sweepstakes-form-section .italic {\n        font-style: italic;\n        font-weight: 400;\n    }\n\n    .sweepstakes-form-section .bold {\n        font-weight: bold;\n    }\n\n    .sweepstakes-form-section .email-input-wrapper {\n        margin-bottom: 12.5em;\n    }\n\n    .sweepstakes-form-section .sweepstakes-section-title {\n        margin: 0 0 0.75em 0;\n        font-size: calc(1.6125 * var(--shopify-root-font-size));\n        font-weight: 400;\n    }\n\n    @media only screen and (max-width: 768px) {\n        .sweepstakes-form-section {\n            --shopify-root-font-size: 13.6px;\n        }\n    }\n\n    #sweepstakes-form {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n    }\n\n    .sweepstakes-form-section .input-wrapper {\n        position: relative;\n        height: 13em;\n        --input-padding-left: 1.5em;\n        border: 0.5em solid #B2BEC6;\n        border-radius: 1.25em;\n        margin-bottom: 12.5em;\n        width: min(100%, 120em);\n    }\n\n    .sweepstakes-form-section .input-label {\n        font-size: 2.5em;\n        position: absolute;\n        top: 0.2em;\n        left: var(--input-padding-left);\n    }\n\n    #sweepstakes-email {\n        --modifier: 3; /* change font-size of input text while maintaining label alignment */\n        --top-padding: 1em;\n        height: 100%;\n        border: none;\n        font-size: calc(1em * var(--modifier)) !important;\n        padding: var(--top-padding) 0 0 calc(var(--input-padding-left) * calc(5 / calc(2 * var(--modifier))));\n        width: 100%;\n    }\n\n    .sweepstakes-form-section .input-field:focus {\n        outline: none;\n    }\n\n    .button-wrapper {\n        display: flex;\n        flex-direction: row;\n        align-items: center;\n        justify-content: center;\n        width: min(100%, 30em);\n        font-size: 3.5em;\n    }\n\n    .button-wrapper > * {\n        width: 100%;\n    }\n\n    .button-wrapper > *:not(:last-child) {\n        margin-right: calc(10em / 7);\n    }\n\n    #sweepstakes-submit-button {\n        background-color: var(--arccos-green);\n        border-radius: calc(5em / 14);\n        font-weight: bold;\n        color: white;\n        border: none;\n        padding: 1em 0;\n        cursor: pointer;\n        font-size: inherit;\n    }\n\n    #sweepstakes-join-link {\n        --border-width: calc(1em / 7);\n        color: var(--color-1);\n        border: var(--border-width) solid var(--color-1);\n        border-radius: calc(5em / 14);\n        background: none;\n        padding: calc(1em - var(--border-width)) 0;\n        text-decoration: none;\n    }\n\n    #sweepstakes-join-link::after {\n        content: none !important;\n    }\n\n    #sweepstakes-join-link:hover {\n        text-decoration: none;\n        cursor: pointer;\n    }\n\n    #sweepstakes-submit-button:disabled {\n        background-color: var(--disabled-button-color);\n        cursor: not-allowed;\n    }\n\n    #bang-svg {\n        position: absolute;\n        top: 1.5em;\n        right: 2em;\n        display: none;\n    }\n\n    #checkmark-svg {\n        margin-bottom: 5em;\n    }\n\n    .sweepstakes-form-section .text {\n        margin: 0;\n        padding: 0;\n    }\n\n    #sweepstakes-entry-info-section {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n    }\n</style>\n<script>\n    let failureCount = 0\n\n    const handleSubmit = async e => {\n        const email = e.target['sweepstakes-email'].value\n        const response = await window.fetch('https://api.arccosgolf.com/v1/offers/sweepstakes/entries', {\n            method: 'POST',\n            headers: {\n                'Content-Type': 'application/json',\n            },\n            body: JSON.stringify({\n                email,\n            })\n        })\n        const json = await response.json()\n        // add visibility hidden\n        if (json.isEmailRegistered) {\n            $('#sweepstakes-entry-layout').css('visibility', 'hidden')\n            $('#sweepstakes-success-layout').css('display', 'flex')\n        } else {\n            failureCount++\n            $('#sweepstakes-entry-info-section').css('visibility', 'hidden')\n            $('#sweepstakes-failure-info-section').css('display', 'flex')\n            $('#bang-svg').css('display', 'block')\n            $('#sweepstakes-email').css('padding-right', '4em')\n            if (failureCount >= 3) {\n                // replace failure text div content with new text\n                $('#failure-text-div').html('<p class=\"text\">Please Email <a href=\"mailto:starter@arccosgolf.com?subject=Arccos%20Invitational%20Inquiry\">starter@arccosgolf.com</a></p>')\n            }\n        }\n    }\n\n    const enableSmoothScrolling = () => {\n        document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {\n            anchor.addEventListener('click', function (e) {\n                e.preventDefault()\n                document.querySelector(this.getAttribute('href')).scrollIntoView({\n                    behavior: 'smooth'\n                })\n            })\n        })\n    }\n\n    const setup = () => {\n        $('#sweepstakes-form')\n            .removeAttr('onsubmit')\n            .submit(e => {\n                e.preventDefault()\n                handleSubmit(e)\n            })\n        $('#sweepstakes-submit-button')\n            .removeAttr('disabled')\n        $('p').filter(function () {\n            return $(this).text() === 'NOT A MEMBER?'\n        })\n            .attr('name', 'arccos-bundle-anchor')\n            .attr('id', 'arccos-bundle-anchor')\n        enableSmoothScrolling()\n    }\n\n    let intervalId\n\n    if (!intervalId) {\n        intervalId = setInterval(() => {\n            if (typeof $ !== 'undefined') {\n                clearInterval(intervalId)\n                intervalId = undefined\n                setup()\n            }\n        }, 300)\n    }\n</script>\n<div id=\"sweepstakesformsection\" name=\"sweepstakesformsection\" class=\"sweepstakes-form-section\">\n    <div id=\"sweepstakes-entry-layout\">\n        <div class=\"sweepstakes-info-section-wrapper\">\n            <div id=\"sweepstakes-entry-info-section\">\n                <h2 class=\"sweepstakes-section-title\">\n                    Enter To Win an Arccos One-of-a-Kind Experience\n                </h2>\n                <div class=\"sweepstakes-section-text\">\n          <span class=\"text\">\n            Active Annual Arccos Members, enter your email below for an opportunity to win an exclusive experience at TPC Sawgrass. 12 Lucky Arccos members will have the chance to compete in the 2024 Arccos Invitational.\n          </span>\n                    <div class=\"br\"></div>\n                    <span class=\"italic text\">\n            Next 4 winners will be selected on January 15, 2024\n          </span>\n                </div>\n            </div>\n            <div id=\"sweepstakes-failure-info-section\">\n                <h2 class=\"sweepstakes-section-title\">\n                    We Don't Recognize Your Email.\n                </h2>\n                <div id=\"failure-text-div\" class=\"sweepstakes-section-text\">\n                    <p class=\"text\">\n                        Check your spelling and re-enter your email. Not an Annual Arccos member? Join Arccos today!\n                    </p>\n                                  </div>\n            </div>\n        </div>\n        <form id=\"sweepstakes-form\">\n            <div class=\"input-wrapper\">\n                <label class=\"input-label\" for=\"sweepstakes-email\">Email Address</label>\n                <input id=\"sweepstakes-email\" required autocomplete=\"email\" name=\"email\" type=\"text\">\n                <svg id=\"bang-svg\" xmlns=\"http://www.w3.org/2000/svg\" width=\"35\" height=\"35\" viewbox=\"0 0 35 35\" fill=\"none\">\n                    <circle cx=\"17.5\" cy=\"17.5\" r=\"17.5\" fill=\"#8F8F8F\"></circle>\n                    <path d=\"M17.6126 21.6215C16.761 21.6215 16.0516 20.9688 15.9809 20.1202L15.126 9.8611C15.0048 8.40635 16.1528 7.15869 17.6126 7.15869C19.0723 7.15869 20.2204 8.40635 20.0991 9.8611L19.2442 20.1202C19.1735 20.9688 18.4641 21.6215 17.6126 21.6215Z\" fill=\"white\"></path>\n                    <path d=\"M17.6126 28.636C16.4477 28.636 15.5034 27.6917 15.5034 26.5268C15.5034 25.3619 16.4477 24.4176 17.6126 24.4176C18.7774 24.4176 19.7217 25.3619 19.7217 26.5268C19.7217 27.6917 18.7774 28.636 17.6126 28.636Z\" fill=\"white\"></path>\n                </svg>\n            </div>\n            <div class=\"button-wrapper\">\n                <button id=\"sweepstakes-submit-button\" type=\"submit\" disabled>\n                    ENTER TO WIN*\n                </button>\n                <a id=\"sweepstakes-join-link\" href=\"https://www.arccosgolf.com/collections/arccos-products\" target=\"_blank\" rel=\"noopener\">\n                    BECOME A MEMBER\n                </a>\n            </div>\n        </form>\n    </div>\n    <div id=\"sweepstakes-success-layout\">\n        <svg id=\"checkmark-svg\" xmlns=\"http://www.w3.org/2000/svg\" width=\"44\" height=\"44\" viewbox=\"0 0 44 44\" fill=\"none\">\n            <circle cx=\"22\" cy=\"22\" r=\"21.25\" fill=\"#56C271\" stroke=\"#56C271\" stroke-width=\"1.5\"></circle>\n            <rect x=\"12.7109\" y=\"22.1333\" width=\"10.3706\" height=\"2.75014\" rx=\"1.37507\" transform=\"rotate(45 12.7109 22.1333)\" fill=\"white\"></rect>\n            <rect x=\"32.7617\" y=\"16.7451\" width=\"20.7412\" height=\"2.75576\" rx=\"1.37788\" transform=\"rotate(135 32.7617 16.7451)\" fill=\"white\"></rect>\n        </svg>\n        <h2 class=\"sweepstakes-section-title\">\n            You've Successfully Entered!\n        </h2>\n        <div class=\"sweepstakes-section-text\">\n            <p class=\"text\">\n                Thanks for entering! The next four (4) winners will be selected on January 15, 2024, and will be notified via email. *Terms and conditions apply. Void where prohibited. US residents only.\n            </p>\n        </div>\n    </div>\n</div>",

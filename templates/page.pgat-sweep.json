    "faq_MrwJqP": {
      "type": "faq",
      "blocks": {
        "question_JADPPC": {
          "type": "question",
          "settings": {
            "title": "How many times can I enter?",
            "text": "<p>One entry per member. Submitting more than once, will not increase your chance of being chosen.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_UYrbC4": {
          "type": "question",
          "settings": {
            "title": "Can I enter, but have a friend go in my place?",
            "text": "<p>The sweepstake is only available to the entered members, if you are not available during the Invitational days, we will draw another member at random.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_ajhgcz": {
          "type": "question",
          "settings": {
            "title": "Is there a Handicap/Skill requirement?",
            "text": "<p>Nope! Anyone can enter regardless of handicap or skill. We just ask you to be courteous and keep up with the group ahead of you. </p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_JTHNdx": {
          "type": "question",
          "settings": {
            "title": "What is the Event Format? ",
            "text": "<p>The Event will be based on a team point system. </p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_crUeXA": {
          "type": "question",
          "settings": {
            "title": "Can I bring a spouse or friend? ",
            "text": "<p>While you can have a spouse or friend accompany you on your trip, please note that due to space limitations, we cannot accommodate additional guests on the course or at the scheduled golf, events, and receptions.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_iTAnBg": {
          "type": "question",
          "settings": {
            "title": "Do I need to submit my entry again for the next drawing?",
            "text": "<p>There's no need to submit your entry again. Your entry remains eligible for all the upcoming drawings.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },

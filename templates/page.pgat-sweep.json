    "rich_text_g8m9J3": {
      "type": "rich-text",
      "blocks": {
        "heading_gWJnHi": {
          "type": "heading",
          "settings": {
            "heading": "Sweepstakes Details",
            "heading_size": "title-sm",
            "heading_tag": "h2",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "text_PKQ8mU": {
          "type": "text",
          "settings": {
            "text": "<p>The Sweepstakes begins on Wednesday, Nov 1, 2023, at 12:00 a.m. EST and ends on Monday, Jan. 15, 2024, at 11:59 p.m. EST.</p><p><strong>Drawing 1</strong> - First 4 winners were selected on November 15, 2023<br/><strong>Drawing 2</strong> - Next 4 winners will be selected on December 15, 2023<br/><strong>Drawing 3</strong> - Last 4 winners will be selected on January 15, 2024</p><p>The winner must be available from Tuesday, March 26, 2024, to Wednesday, March 27, 2024, to redeem the prize.</p><p>*<a href=\"/pages/arccos-invitational-at-tpc-sawgrass-official-rules\" target=\"_blank\" title=\"The 2024 Arccos Invitational at TPC Sawgrass Sweepstakes (the “Sweepstakes”) March 26, 2024 and March 27, 2024\">Terms and conditions</a> apply. Void where prohibited. US residents only.<br/><br/><a href=\"/blogs/community/arccos-invitational-first-four-winners-announced\" target=\"_blank\" title=\"/blogs/community/arccos-invitational-first-four-winners-announced\">First Four Winners Announced</a></p>",
            "text_size": "subtext-md",
            "text_max_size": 32,
            "text_font": "body",
            "secondary_color": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }

      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "liquid": "<div class=\"free-trial-page-wrapper\">\n  <style>\n    .free-trial-page-wrapper {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      position: relative;\n      background-image:\n        linear-gradient(rgba(0,0,0,.4), rgba(0,0,0,.6)),\n        url('https://cdn.shopify.com/s/files/1/0780/5525/files/Group_1129.jpg?v=1706876314');\n      background-size: cover;\n      background-repeat: no-repeat;\n      padding: max(10px, 5vw);\n      width: 100%;\n      margin-bottom: 0 !important;\n      min-height: max(70vh, 400px);\n    }\n\n    .partner-images {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      grid-template-rows: 1fr 1fr;\n      align-items: center;\n      justify-content: center;\n      gap: max(10px, 2vw); /* grid-gap -> gap */\n      width: 100%;\n      max-width: 1200px;\n    }\n\n    @media (min-width: 768px) {\n      .partner-images {\n        grid-template-columns: 1fr 1fr 1fr 1fr;\n        grid-template-rows: 1fr;\n      }\n    }\n\n    .partner-image-container {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .partner-link {\n      height: 100%;\n      width: 100%;\n      display: block;\n    }\n\n    .partner-image {\n      width: 100%;\n      height: auto;\n      display: block;\n    }\n\n    .text-content {\n      color: white;\n      text-align: center;\n      margin-bottom: max(30px, 3vw);\n      line-height: 1.5;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .title-text {\n      font-family: inherit;\n      font-size: min(7vw, 40px);\n      text-transform: none;\n      line-height: 1;\n      margin: 0.25em 0 0.1em;\ncolor: #ffffff;\n    }\n\n    .subtext {\n      font-size: min(3.5vw, 18px);\n      color: #B2BEC6;\n      line-height: 1.25;\n    }\n\n    .no-clubs-option {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      margin-top: max(24px, 3vw);\n      margin-bottom: max(50px, 5vw);\n    }\n\n    .no-clubs-option > a {\n      color: white;\n      text-decoration: underline;\n      text-align: center;\n      opacity: 0.9;\n      font-size: 14px;\n      width: 100%;\n    }\n\n    .pga-logo {\n      height: 3.75em;\n      width: auto;\n      display: inline-block;\n    }\n  </style>\n\n  <div class=\"header\">\n    <img\n      class=\"pga-logo\"\n      src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/official-game-tracker-pga.svg?v=1692031498\"\n      alt=\"PGA TOUR Official Game Tracker\">\n  </div>\n\n  <div class=\"text-content\">\n    <h1 class=\"title-text\">Get free Arccos sensors and a free trial.</h1>\n    <div class=\"subtext\">Select your brand below to learn more about their program and get started!</div>\n  </div>\n\n  <div class=\"partner-images\">\n    <div class=\"partner-image-container\">\n      <a class=\"partner-link\" href=\"https://ping.arccosgolf.com/\">\n        <img alt=\"PING\" class=\"partner-image\" src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Group_2330.png?v=1652367998\">\n      </a>\n    </div>\n\n    <div class=\"partner-image-container\">\n      <a class=\"partner-link\" href=\"https://taylormade.arccosgolf.com/\">\n        <img alt=\"TaylorMade\" class=\"partner-image\" src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Group_2333.png?v=1652367998\">\n      </a>\n    </div>\n\n    <div class=\"partner-image-container\">\n      <a class=\"partner-link\" href=\"https://cobra.arccosgolf.com/\">\n        <img alt=\"Cobra\" class=\"partner-image\" src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Group_2332.png?v=1652367998\">\n      </a>\n    </div>\n\n    <div class=\"partner-image-container\">\n      <a class=\"partner-link\" href=\"https://dunlopsports.arccosgolf.com/\">\n        <img alt=\"Srixon\" class=\"partner-image\" src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Cleveland_srixon_430x.png?v=1705938699\">\n      </a>\n    </div>\n  </div>\n\n  <h4 class=\"no-clubs-option\">\n    <a class=\"partner-link\" href=\"https://activate.arccosgolf.com/?affiliate=ArccosTV\">Don’t have any of these clubs?</a>\n  </h4>\n\n  <script>\n    (function () {\n      var links = document.getElementsByClassName('partner-link');\n      var pageParams = new URLSearchParams(window.location.search);\n\n      for (var i = 0; i < links.length; i++) {\n        var a = links[i];\n        var href = a.getAttribute('href');\n\n        // Skip if no href\n        if (!href) continue;\n\n        // Build absolute URL for manipulation\n        var url = new URL(href, window.location.origin);\n\n        // Merge page query params without duplicating existing keys\n        pageParams.forEach(function (value, key) {\n          if (!url.searchParams.has(key)) {\n            url.searchParams.set(key, value);\n          }\n        });\n\n        // Preserve relative URLs for same-origin paths\n        if (url.origin === window.location.origin) {\n          a.setAttribute('href', url.pathname + (url.search ? url.search : ''));\n        } else {\n          a.setAttribute('href', url.toString());\n        }\n      }\n    })();\n  </script>\n</div>",

    "faq_8XYCd7": {
      "type": "faq",
      "blocks": {
        "question_kkQ9cg": {
          "type": "question",
          "settings": {
            "title": "How easy are the grips to install?",
            "text": "<p>Arccos Smart Grips are installed in the same way normal golfs grips are fitted. The grips come with the sensors already installed and there is no need to remove these before fitting the grips.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_gA4Can": {
          "type": "question",
          "settings": {
            "title": "Is my course mapped?",
            "text": "<p>We have over 40,000 courses mapped in our system. To see if your course is mapped, use our course search tool.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_Xzd3JJ": {
          "type": "question",
          "settings": {
            "title": "Do sensors require battery replacements?",
            "text": "<p>Batteries are not replaceable. The sensors have a 2-year guarantee and each member receives 5 new sensors upon membership renewal.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_keEtAX": {
          "type": "question",
          "settings": {
            "title": "Are the sensors waterproof?",
            "text": "<p>Arccos Smart Sensors are weather and dust resistant. If you get caught out by the weather mid-round, don't worry we'll keep tracking your shots!</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },

on {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      margin-bottom: max(50px, 5vw);\n    }\n\n    .no-clubs-option > a {\n      color: white;\n      text-decoration: underline;\n      text-align: center;\n      opacity: 0.8;\n      font-size: 14px;\n      width: 100%;\n    }\n\n    .pga-logo {\n      height: 3.75em;\n      width: auto;\n      display: inline-block;\n    }\n  </style>\n\n  <div class=\"header\">\n    <img\n      class=\"pga-logo\"\n      src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/official-game-tracker-pga.svg?v=1692031498\"\n      alt=\"PGA TOUR Official Game Tracker\">\n  </div>\n\n  <div class=\"text-content\">\n    <h1 class=\"title-text\">Choose A Membership</h1>\n    <div class=\"subtext\">Join Arccos Today &amp; Access Golf's #1 Game Tracker.</div>\n  </div>\n\n  <div class=\"membership-images\">\n    <div class=\"membership-image-container\">\n      <a class=\"membership-link\" href=\"https://activate.arccosgolf.com/?utm_source=joinnow&utm_medium=referral&utm_campaign=landingpage\">\n        <img alt=\"Free Sensors\" class=\"membership-image\" src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/FreeSensors.png?v=17503470352\">\n      </a>\n    </div>\n\n    <div class=\"membership-image-container\">\n      <a class=\"membership-link\" href=\"/products/smart-sensors/?utm_source=joinnow&utm_medium=referral&utm_campaign=landingpage\">\n        <img alt=\"Annual Membership\" class=\"membership-image\" src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Annual.png?v=1750347408\">\n      </a>\n    </div>\n\n    <div class=\"membership-image-container\">\n      <a class=\"membership-link\" href=\"/products/arccos-starter-bundle/?utm_source=joinnow&utm_medium=referral&utm_campaign=landingpage\">\n        <img alt=\"Bundle Membership\" class=\"membership-image\" src=\"https://cdn.shopify.com/s/files/1/0780/5525/files/Bundle.png?v=1750347407\">\n      </a>\n    </div>\n  </div>\n\n  <script>\n    (function () {\n      var links = document.getElementsByClassName('membership-link');\n      var pageParams = new URLSearchParams(window.location.search);\n\n      // Append any page query params to each membership link if they aren't already present\n      for (var i = 0; i < links.length; i++) {\n        var a = links[i];\n        var url = new URL(a.getAttribute('href'), window.location.origin);\n\n        pageParams.forEach(function (value, key) {\n          if (!url.searchParams.has(key)) {\n            url.searchParams.set(key, value);\n          }\n        });\n\n        // Keep same path + merged params (avoid duplicating the domain on relative links)\n        if (url.origin === window.location.origin) {\n          a.setAttribute('href', url.pathname + (url.searchParams.toString() ? '?' + url.searchParams.toString() : ''));\n        } else {\n          a.setAttribute('href', url.toString());\n        }\n      }\n    })();\n  </script>\n</div>",

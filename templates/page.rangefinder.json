    "faq_cTaTCf": {
      "type": "faq",
      "blocks": {
        "question_fzLTrA": {
          "type": "question",
          "settings": {
            "title": "What is Arccos Strokes Gained Analytics (SGA)?",
            "text": "<p>Strokes Gained (SG) is a revolutionary way to analyze the data behind your game. We use our A.I. neural network to accurately compare your current game versus a target handicap of your choosing. Thanks to our vast range of benchmarking options and the largest set of on-course data worldwide, we’re able to provide insights within your player stats for each facet of your game, plus clear ways to improve from world-class coaches.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_XFCBkT": {
          "type": "question",
          "settings": {
            "title": "How do I see an individual round’s Arccos Strokes Gained Analytics?",
            "text": "<p>To check your individual round stats, go to the <strong>Rounds</strong> tab and select <strong>Stats</strong> under the round you want to review.</p><p>As long as you've played <strong>6 holes or more</strong>, you'll see a detailed <strong>Strokes Gained</strong> analysis for that round.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_yiA9V6": {
          "type": "question",
          "settings": {
            "title": "What gets calculated into the Arccos Short Game facet?",
            "text": "<p>Arccos Short Game facet factors in both your chipping and sand performance from 0-25 yards and 25-50 yards of the green. </p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_UFJfAP": {
          "type": "question",
          "settings": {
            "title": "What is the Trend Analysis?",
            "text": "<p>Your <strong>Trend Analysis</strong> chart provides a visual overview of your game’s progression from a <strong>Strokes Gained</strong> perspective. Each round is mapped out, showing your total <strong>SG</strong> for the round, as well as SG stats for each individual facet of your game.</p><ul><li><strong>Selector:</strong> Drag the selector left or right to focus on a specific round.</li><li><strong>Facet Toggle:</strong> You can toggle each facet on and off to zero in on a particular area of your game.</li><li><strong>Grey Bar:</strong> The grey bar in the background compares your overall strokes gained data to your target handicap.</li><li><strong>Colored Lines:</strong> The colored lines represent the performance of each individual facet during that round.</li></ul><p>For a more detailed breakdown of your Strokes Gained Analytics for any given round, simply tap <strong>“See Full Round Details”</strong> for that specific round.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },

    "faq_8XYCd7": {
      "type": "faq",
      "blocks": {
        "question_kkQ9cg": {
          "type": "question",
          "settings": {
            "title": "How easy are the sensors to install?",
            "text": "<p>Arccos Smart Sensors are really easy to install with twist-in sensors that are compatible with most golf clubs. Typical set up takes less than 10 minutes but requires an internet connection.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_gA4Can": {
          "type": "question",
          "settings": {
            "title": "Is my course mapped?",
            "text": "<p>We have over 40,000 courses mapped in our system. To see if your course is mapped, use our course search tool.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_Xzd3JJ": {
          "type": "question",
          "settings": {
            "title": "Do sensors require battery replacements?",
            "text": "<p>Batteries are not replaceable. The sensors have a 2-year guarantee and each member receives 5 new sensors upon membership renewal.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_keEtAX": {
          "type": "question",

    "testimonials_F7gWYb": {
      "type": "testimonials",
      "blocks": {
        "testimonial_RkbdTU": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>I've been playing golf for 20 years now, been an Arccos user for 5 months, over that 5 month span I've gone from a 15 handicap to a 10.</p>",
            "author": "Zach K",
            "author_info": "Arccos Member",
            "author_url": "",
            "image_ratio": "rounded",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",

            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "testimonial_Kmtmt8": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>I’ve been using Arccos for over a year now. The most beneficial thing for me is preparation for tournaments. It allows me to track my stats and Strokes Gained metrics and that’s huge for validating my practice to make sure I am improving.</p>",
            "author": "Zach P",
            "author_info": "Arccos Member",
            "author_url": "",
            "image_ratio": "rounded",
            "button_label": "",
            "button_link": "",

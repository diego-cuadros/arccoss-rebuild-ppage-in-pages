            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "testimonial_7zEB4B": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>Arccos tells you what kind of golfer you are. It tells you your entire golf game. For me it's more about helping me to improve my game. Telling me where I'm at, and where I want to be.</p>",
            "author": "Luiza A",
            "author_info": "Arccos Member",
            "author_url": "",
            "image_ratio": "rounded",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",

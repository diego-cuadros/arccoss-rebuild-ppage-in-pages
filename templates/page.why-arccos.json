        },
        "content_qMcm8D": {
          "type": "content",
          "settings": {
            "image": "shopify://shop_images/PersonalInsights.jpg",
            "subheading": "Insights",
            "heading": "<strong>Strokes Gained Analytics</strong>",
            "heading_tag": "h2",
            "text": "<p>The most advanced personalized insights in the game, provides players with a clear and simple way to improve. Top 3 Insights show exactly what to work on. In depth analysis for every facet of the game: driving, approach, short, and putting, plus tips from world-class coaches.</p>",
            "button_label": "Learn More",
            "button_link": "shopify://pages/strokes-gained-analytics",
            "button_style": "secondary",
            "button_external": false,

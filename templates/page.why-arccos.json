          "settings": {
            "image": "shopify://shop_images/CourseStrategy.jpg",
            "subheading": "Caddie Advice",
            "heading": "Real-Time Course Strategy",
            "heading_tag": "h2",
            "text": "<p>Powered by your data, Arccos uses a wide variety of inputs to provide a golfer with real-time insights into their optimal and alternative strategies, as well as outcome predictions, for every shot they play.</p>",
            "button_label": "Learn More",
            "button_link": "shopify://pages/ai-strategy",
            "button_style": "secondary",
            "button_external": false,
            "button_icon": false,

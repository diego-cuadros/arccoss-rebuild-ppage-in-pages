    "testimonials_F7gWYb": {
      "type": "testimonials",
      "blocks": {
        "testimonial_RkbdTU": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>I’m excited about the new Air because it’s lighter and smaller than my phone, works in my pocket and lasts 12 rounds with the new charging case!</p>",

            "author_info": "Arccos Ambassador",
            "author_url": "",
            "image_ratio": "rounded",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
            "button_video": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "testimonial_Kmtmt8": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>The new Air performs extremely well.  The battery pack allows me to play multiple games without having to remember to charge the Air between rounds and ability to easily mark the pin is a plus.</p>",

    "faq_cTaTCf": {
      "type": "faq",
      "blocks": {
        "question_fzLTrA": {
          "type": "question",
          "settings": {
            "title": "What are Top Shots and Tour Quality Shots?",
            "text": "<p>Arccos is excited to launch our new Top Shots and Tour Quality Shots to highlight the best shots in your given round. Top Shots celebrates some of your best moments from each round. Exceptional approach shots are tagged PGA TOUR Quality (TQS) when your proximity to the hole is better than PGA TOUR average. Please, set the hole location and/or confirm your first putt distance for best results. </p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_WkWHHK": {
          "type": "question",
          "settings": {
            "title": "How do I achieve Tour Quality Shots?",
            "text": "<p>Tour Quality Shots: You must edit the flag location for a Tour Quality Shots to be attributed properly. Multiple TQS's can be attributed in a single round.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_XFCBkT": {
          "type": "question",
          "settings": {
            "title": "How do I achieve Top Shots?",
            "text": "<p>Top Shots: No editing needed, we automatically assign the best shots to your round. The highest SG (strokes gained) on a single shot, multiple Top Shots can be attributed in a single round.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_yiA9V6": {
          "type": "question",
          "settings": {
            "title": "How do I view & share Top Shots and Tour Quality Shots?",
            "text": "<p>To view your Tour Quality Shots/Top Shots go to the Activity screen/tab after your round.</p><p>To Share a TQS or TO use the \"Share your shot\" button.</p><p>TQS and Top Shots are only eligible in NEW rounds, these are not available for previously recorded rounds.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },

            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "testimonial_mXNpNP": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>Strokes Gained information might seem like it is only for Tour players. No it is not; it is for you. And I believe every golfer, once they see the new Arccos SGA, will gain perspective of what better stats and better decision making brings to the table, and they are going to play better golf.</p>",
            "author": "Andrew Rice",
            "author_info": "Arccos Ambassador",

    "testimonials_8etTtp": {
      "type": "testimonials",
      "blocks": {
        "testimonial_ECCwKf": {
          "type": "testimonial",
          "settings": {
            "icon": "quote",
            "text": "<p>Strokes gained data can reveal so much. The problem with it up until this point is that the benchmarks were PGA Tour players and scratch golfers. This is overwhelming if you’re a 20 handicap. Now with Arccos SGA it is truly amazing.</p>",
            "author": "Trillium Rose",
            "author_info": "Arccos Ambassador",
            "author_url": "",
            "image": "shopify://shop_images/Trillium_Rose_360x_b20af66a-ae09-4096-addd-762ef10bc4d8.jpg",
            "image_ratio": "rounded",
            "button_label": "",
